<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.mardous.projectmusic.ui.screen.library.home.HomeFragment"
        android:label="HomeFragment"/>

    <fragment
        android:id="@+id/nav_songs"
        android:name="com.mardous.projectmusic.ui.screen.library.songs.SongListFragment"
        android:label="SongsFragment"/>

    <fragment
        android:id="@+id/nav_albums"
        android:name="com.mardous.projectmusic.ui.screen.library.albums.AlbumListFragment"
        android:label="AlbumsFragment"/>

    <fragment
        android:id="@+id/nav_artists"
        android:name="com.mardous.projectmusic.ui.screen.library.artists.ArtistListFragment"
        android:label="ArtistsFragment"/>

    <fragment
        android:id="@+id/nav_genres"
        android:name="com.mardous.projectmusic.ui.screen.library.genres.GenresListFragment"
        android:label="GenresFragment"/>

    <fragment
        android:id="@+id/nav_years"
        android:name="com.mardous.projectmusic.ui.screen.library.years.YearsListFragment"
        android:label="YearsFragment"/>

    <fragment
        android:id="@+id/nav_playlists"
        android:name="com.mardous.projectmusic.ui.screen.library.playlists.PlaylistListFragment"
        android:label="PlaylistsFragment"/>

    <fragment
        android:id="@+id/nav_folders"
        android:name="com.mardous.projectmusic.ui.screen.library.folders.FoldersListFragment"
        android:label="FoldersFragment"/>

    <fragment
        android:id="@+id/nav_search"
        android:name="com.mardous.projectmusic.ui.screen.library.search.SearchFragment"
        android:label="SearchFragment">
        <argument
            android:name="query"
            app:argType="string"
            app:nullable="true"/>
        <argument
            android:name="filter"
            app:argType="com.mardous.projectmusic.data.SearchFilter"
            app:nullable="true"/>
    </fragment>

    <dialog
        android:id="@+id/nav_queue"
        android:name="com.mardous.projectmusic.ui.screen.queue.QueueFragment"
        android:label="QueueFragment"/>

    <fragment
        android:id="@+id/nav_album_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.albums.AlbumDetailFragment"
        android:label="AlbumDetailFragment">
        <argument
            android:name="album_id"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/nav_artist_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.artists.ArtistDetailFragment"
        android:label="ArtistDetailFragment">
        <argument
            android:name="artist_id"
            app:argType="long"/>
        <argument
            android:name="artist_name"
            app:argType="string"
            app:nullable="true"/>
    </fragment>

    <fragment
        android:id="@+id/nav_playlist_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.playlists.PlaylistDetailFragment"
        android:label="PlaylistDetailFragment">
        <argument
            android:name="playlistId"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/nav_genre_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.genres.GenreDetailFragment"
        android:label="GenreDetailFragment">
        <argument
            android:name="extraGenre"
            app:argType="com.mardous.projectmusic.data.model.Genre"/>
    </fragment>

    <fragment
        android:id="@+id/nav_year_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.years.YearDetailFragment"
        android:label="YearDetailFragment">
        <argument
            android:name="extraYear"
            app:argType="integer"/>
    </fragment>

    <fragment
        android:id="@+id/nav_folder_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.folders.FolderDetailFragment"
        android:label="FolderDetailFragment">
        <argument
            android:name="extraFolderPath"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/nav_detail_list"
        android:name="com.mardous.projectmusic.ui.screen.other.DetailListFragment"
        android:label="DetailListFragment">
        <argument
            android:name="type"
            app:argType="com.mardous.projectmusic.data.model.ContentType"/>
    </fragment>

    <fragment
        android:id="@+id/nav_lyrics"
        android:name="com.mardous.projectmusic.ui.screen.lyrics.LyricsFragment"
        android:label="LyricsFragment"/>

    <fragment
        android:id="@+id/nav_lyrics_editor"
        android:name="com.mardous.projectmusic.ui.screen.lyrics.LyricsEditorFragment"
        android:label="LyricsEditorFragment">
        <argument
            android:name="extraSong"
            app:argType="com.mardous.projectmusic.data.model.Song" />
    </fragment>

    <dialog
        android:id="@+id/nav_song_details"
        android:name="com.mardous.projectmusic.ui.screen.info.SongDetailFragment"
        android:label="SongDetailFragment">
        <argument
            android:name="extraSong"
            app:argType="com.mardous.projectmusic.data.model.Song" />
    </dialog>

    <dialog
        android:id="@+id/nav_sleep_timer"
        android:name="com.mardous.projectmusic.ui.screen.sleeptimer.SleepTimerFragment"
        android:label="SleepTimerFragment">
    </dialog>

    <fragment
        android:id="@+id/nav_play_info"
        android:name="com.mardous.projectmusic.ui.screen.info.PlayInfoFragment"
        android:label="PlayInfoFragment">
        <argument
            android:name="isArtist"
            app:argType="boolean" />
        <argument
            android:name="id"
            app:argType="long" />
        <argument
            android:name="name"
            app:argType="string"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_equalizer"
        android:name="com.mardous.projectmusic.ui.screen.equalizer.EqualizerFragment"
        android:label="EqualizerFragment">
        <argument
            android:name="from_player"
            app:argType="boolean"
            android:defaultValue="false" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.mardous.projectmusic.ui.screen.settings.SettingsFragment"
        android:label="SettingsFragment"/>

    <dialog
        android:id="@+id/nav_sound_settings"
        android:name="com.mardous.projectmusic.ui.screen.sound.SoundSettingsFragment"
        android:label="SoundSettingsFragment"/>

    <fragment
        android:id="@+id/nav_stats"
        android:name="com.mardous.projectmusic.ui.screen.stats.StatsFragment"
        android:label="StatsFragment">
        <action
            android:id="@+id/action_nav_stats_to_nav_stats_detail"
            app:destination="@id/nav_stats_detail"/>
    </fragment>

    <fragment
        android:id="@+id/nav_stats_detail"
        android:name="com.mardous.projectmusic.ui.screen.stats.StatsDetailFragment"
        android:label="StatsDetailFragment">
        <argument
            android:name="category"
            app:argType="string"/>
        <argument
            android:name="itemName"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/nav_library_stats"
        android:name="com.mardous.projectmusic.ui.screen.librarystats.LibraryStatsFragment"
        android:label="LibraryStatsFragment"/>

    <fragment
        android:id="@+id/nav_about"
        android:name="com.mardous.projectmusic.ui.screen.about.AboutFragment"
        android:label="AboutFragment"/>
    <fragment
        android:id="@+id/nav_library_stats_detail"
        android:name="com.mardous.projectmusic.ui.screen.librarystats.LibraryStatsDetailFragment"
        android:label="LibraryStatsDetailFragment">
        <argument
            android:name="category"
            app:argType="string"/>
        <argument
            android:name="itemName"
            app:argType="string"/>
    </fragment>

    <fragment
        android:id="@+id/nav_moods"
        android:name="com.mardous.projectmusic.ui.screen.library.moods.MoodsFragment"
        android:label="MoodsFragment"/>

    <fragment
        android:id="@+id/nav_mood_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.moods.MoodDetailFragment"
        android:label="MoodDetailFragment">
        <argument
            android:name="mood_id"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/nav_tags"
        android:name="com.mardous.projectmusic.ui.screen.library.tags.TagsFragment"
        android:label="TagsFragment"/>

    <fragment
        android:id="@+id/nav_tag_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.tags.TagDetailFragment"
        android:label="TagDetailFragment">
        <argument
            android:name="tag_id"
            app:argType="long"/>
    </fragment>

    <fragment
        android:id="@+id/nav_instruments"
        android:name="com.mardous.projectmusic.ui.screen.library.instruments.InstrumentsFragment"
        android:label="InstrumentsFragment"/>

    <fragment
        android:id="@+id/nav_instrument_detail"
        android:name="com.mardous.projectmusic.ui.screen.library.instruments.InstrumentDetailFragment"
        android:label="InstrumentDetailFragment">
        <argument
            android:name="instrument_id"
            app:argType="long"/>
    </fragment>

</navigation>