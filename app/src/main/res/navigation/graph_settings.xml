<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_graph"
    app:startDestination="@id/nav_home_preferences">
    <fragment
        android:id="@+id/nav_home_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.SettingsDashboardFragment"
        android:label="@string/settings_title">
        <action
            android:id="@+id/action_to_appearancePreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_interface_preferences"/>
        <action
            android:id="@+id/action_to_nowPlayingPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_now_playing_preferences"/>
        <action
            android:id="@+id/action_to_lyricsPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_lyrics_preferences"/>
        <action
            android:id="@+id/action_to_playbackPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_playback_preferences"/>
        <action
            android:id="@+id/action_to_metadataPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_metadata_preferences"/>
        <action
            android:id="@+id/action_to_libraryPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_library_preferences"/>
        <action
            android:id="@+id/action_to_networkPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_network_preferences"/>
        <action
            android:id="@+id/action_to_advancedPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_advanced_preferences"/>
    </fragment>
    <fragment
        android:id="@+id/nav_interface_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.AppearancePreferencesFragment"
        android:label="@string/appearance_title">
        <action
            android:id="@+id/action_to_swipeActionsPreferences"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_swipe_actions_preferences"/>
    </fragment>
    <fragment
        android:id="@+id/nav_swipe_actions_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.SwipeActionsPreferencesFragment"
        android:label="@string/swipe_actions_title"/>
    <fragment
        android:id="@+id/nav_now_playing_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.NowPlayingPreferencesFragment"
        android:label="@string/now_playing_title"/>
    <fragment
        android:id="@+id/nav_lyrics_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.LyricsPreferencesFragment"
        android:label="@string/lyrics_preferences_title"/>
    <fragment
        android:id="@+id/nav_playback_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.PlaybackPreferencesFragment"
        android:label="@string/playback_title"/>
    <fragment
        android:id="@+id/nav_library_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.LibraryPreferencesFragment"
        android:label="@string/library_title"/>
    <fragment
        android:id="@+id/nav_network_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.NetworkPreferencesFragment"
        android:label="@string/network_title">
        <action
            android:id="@+id/action_to_pendingScrobbles"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_pending_scrobbles"/>
        <action
            android:id="@+id/action_to_lastfmProfile"
            app:enterAnim="@anim/projectmusic_fragment_open_enter"
            app:exitAnim="@anim/projectmusic_fragment_open_exit"
            app:popEnterAnim="@anim/projectmusic_fragment_close_enter"
            app:popExitAnim="@anim/projectmusic_fragment_close_exit"
            app:destination="@+id/nav_lastfm_profile"/>
    </fragment>
    <fragment
        android:id="@+id/nav_advanced_preferences"
        android:name="com.mardous.projectmusic.ui.screen.settings.AdvancedPreferencesFragment"
        android:label="@string/advanced_title"/>
    <fragment
        android:id="@+id/nav_pending_scrobbles"
        android:name="com.mardous.projectmusic.ui.screen.scrobbling.PendingScrobblesFragment"
        android:label="Pending Scrobbles"/>
    <fragment
        android:id="@+id/nav_lastfm_profile"
        android:name="com.mardous.projectmusic.ui.screen.scrobbling.LastFmProfileFragment"
        android:label="Last.fm Profile"/>
</navigation>
